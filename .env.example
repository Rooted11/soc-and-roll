# Copy this file to .env and fill in your values.
# Then run: docker compose up --build

# Required for full Claude AI analysis (recommendations, Q&A, executive reports).
# Get a key at https://console.anthropic.com
# Without this key the platform still works — it uses template-based fallback responses.
ANTHROPIC_API_KEY=sk-ant-...

# Database credentials (change in production)
# POSTGRES_USER=soc
# POSTGRES_PASSWORD=soc_pass
# POSTGRES_DB=soc_db
