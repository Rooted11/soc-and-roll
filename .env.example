# Copy this file to .env for local development.
# Then run: docker compose up --build

# Runtime mode
ENVIRONMENT=development

# Local development keeps auth off by default in docker-compose.yml.
# If you turn it on locally, use these values in the login screen and scripts.
AUTH_ENABLED=false
AUTH_USERNAME=soc_operator
AUTH_PASSWORD=change-me-locally
AUTH_TOKEN_SECRET=local-dev-token-secret
AUTH_TOKEN_TTL_MINUTES=480
AUTH_MFA_ENABLED=false
AUTH_TOTP_SECRET=
AUTH_TOTP_ISSUER=Ataraxia

# Optional local rate limiting. The dev compose file keeps this off by default.
RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_REQUESTS=300
API_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# CORS / host restrictions
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
ENABLE_API_DOCS=true

# Claude integration is optional.
# Without this key the platform still works with template-based fallback responses.
ANTHROPIC_API_KEY=

# Database credentials for local development
POSTGRES_USER=soc
POSTGRES_PASSWORD=soc_pass
POSTGRES_DB=soc_db

# Event / queue (optional in dev; enabled in prod compose)
USE_REDIS_STREAMS=true
REDIS_URL=redis://redis:6379/0
LOG_RETENTION_MINUTES=15
